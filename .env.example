# Environment Variables Configuration
# This file documents all available environment variables

# ============================================
# API Keys & Credentials
# ============================================

# GEMINI_API_KEY: Required for Google Gemini AI integration
# Used for voice-over generation and AI-powered features
# Get it from: https://ai.google.dev/
GEMINI_API_KEY=AIzaSyCetV1Sdblye9rwGYb9e_H7_l-SN-sSbbc

# ============================================
# Application Configuration
# ============================================

# NODE_ENV: Application environment (development or production)
# Affects middleware behavior, static file serving, and logging
NODE_ENV=development

# PORT: Server port (defaults to 3000)
# Set this if running on a different port
# PORT=3000

# APP_URL: The URL where this applet is hosted
# AI Studio automatically injects this at runtime with the Cloud Run service URL
# Used for self-referential links and API callbacks
APP_URL=

# ============================================
# Feature Flags
# ============================================

# DISABLE_HMR: Disable Hot Module Replacement in Vite (set to 'true' to disable)
# Used in AI Studio to prevent flickering during agent edits
DISABLE_HMR=false

# ============================================
# Logging & Debugging
# ============================================

# DEBUG: Enable debug logging (set to 'true' for verbose logs)
# DEBUG=false

# LOG_LEVEL: Logging level (debug, info, warn, error)
# LOG_LEVEL=info

